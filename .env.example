# Required: OpenAI API key for content generation
OPENAI_API_KEY=sk-xxxxx

# Site URL (used for sitemap, RSS, social posts)
SITE_URL=https://shelbyaideals.com

# Optional: Auto-commit and push after generating content
GIT_AUTO_COMMIT=false

# Newsletter: Beehiiv publication ID (get from beehiiv.com > Settings > API)
NEXT_PUBLIC_BEEHIIV_PUBLICATION_ID=

# Optional: Twitter/X API for auto-posting
TWITTER_BEARER_TOKEN=

# Optional: LinkedIn API for auto-posting
LINKEDIN_ACCESS_TOKEN=

# Optional: LinkedIn author URN (format: urn:li:person:xxxxx)
LINKEDIN_AUTHOR_URN=
